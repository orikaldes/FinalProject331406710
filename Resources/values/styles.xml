<?xml version="1.0" encoding="utf-8"?>
<resources>

	<style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
		<item name="colorPrimary">#225522</item>
		<item name="colorPrimaryDark">#113311</item>
		<item name="colorAccent">#FFFF00</item>
	</style>

	<style name="MyMenuTheme" parent="ThemeOverlay.AppCompat.Light">
		<item name="android:textColor">#000000</item>
		<item name="android:colorBackground">#FFFFFF</item>
	</style>

	<style name="ForceBlackTextMenu" parent="ThemeOverlay.AppCompat.Light">
		<item name="android:textColor">#000000</item>
		<item name="android:textViewStyle">@style/BlackTextStyle</item>
	</style>

	<style name="BlackTextStyle" parent="android:Widget.TextView">
		<item name="android:textColor">#000000</item>
	</style>

	<style name="CardSlot" parent="Widget.AppCompat.TextView">
		<item name="android:layout_width">50dp</item>
		<item name="android:layout_height">70dp</item>
		<item name="android:background">@drawable/card_background</item>
		<item name="android:text">...</item>
		<item name="android:gravity">center</item>
		<item name="android:textSize">18sp</item>
		<item name="android:textStyle">bold</item>
		<item name="android:textColor">#000000</item>
		<item name="android:layout_margin">4dp</item>
	</style>

</resources>