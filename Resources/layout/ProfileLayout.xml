<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#336933">

	<androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#225522"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ForceBlackTextMenu" />

	<ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

		<LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:padding="20dp">

			<androidx.cardview.widget.CardView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="60dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#225522">
				<FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
					<ImageView
                        android:id="@+id/imgProfile"
                        android:src="@drawable/ic_default_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />
					<TextView
                        android:text="Edit"
                        android:background="#AA000000"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:padding="4dp"
                        android:layout_gravity="bottom"
                        android:layout_width="match_parent"
                        android:gravity="center"
                        android:layout_height="wrap_content" />
				</FrameLayout>
			</androidx.cardview.widget.CardView>

			<TextView
                android:id="@+id/textProfileNameHeader"
                android:text="User Name"
                android:textColor="#FFFF00"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

			<Button
                android:id="@+id/btnFriends"
                android:text="Friends List"
                android:backgroundTint="#222222"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="20dp"
                android:layout_width="150dp"
                android:layout_height="wrap_content" />

			<TextView
                android:text="My World"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_gravity="start"
                android:layout_marginBottom="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

			<androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#225522"
                android:layout_marginBottom="10dp">

				<fragment
                    android:id="@+id/mapFragmentProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    class="com.google.android.gms.maps.SupportMapFragment"
                    app:liteMode="true" />

			</androidx.cardview.widget.CardView>

			<LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

				<TextView
                    android:text="Current Location: "
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

				<TextView
                    android:id="@+id/textCity"
                    android:text="Unknown"
                    android:textSize="16sp"
                    android:textColor="#FFFF00"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content" />

				<ImageButton
                    android:id="@+id/btnEditCity"
                    android:src="@android:drawable/ic_menu_edit"
                    android:background="?android:attr/selectableItemBackground"
                    android:tint="#FFFF00"
                    android:layout_width="40dp"
                    android:layout_height="40dp" />
			</LinearLayout>

			<LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

				<TextView android:text="Full Name:" android:textColor="#CCCCCC" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
				<LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="15dp">
					<TextView
                        android:id="@+id/textFullName"
                        android:text="Loading..."
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content" />
					<ImageButton
                        android:id="@+id/btnEditName"
                        android:src="@android:drawable/ic_menu_edit"
                        android:background="?android:attr/selectableItemBackground"
                        android:tint="#FFFF00"
                        android:layout_width="40dp"
                        android:layout_height="40dp" />
				</LinearLayout>

				<TextView android:text="Email:" android:textColor="#CCCCCC" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
				<LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="15dp">
					<TextView
                        android:id="@+id/textEmail"
                        android:text="Loading..."
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content" />
					<ImageButton
                        android:id="@+id/btnEditEmail"
                        android:src="@android:drawable/ic_menu_edit"
                        android:background="?android:attr/selectableItemBackground"
                        android:tint="#FFFF00"
                        android:layout_width="40dp"
                        android:layout_height="40dp" />
				</LinearLayout>

				<TextView android:text="Age:" android:textColor="#CCCCCC" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
				<LinearLayout android:orientation="horizontal" android:gravity="center_vertical" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="15dp">
					<TextView
                        android:id="@+id/textAge"
                        android:text="Loading..."
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content" />
					<ImageButton
                        android:id="@+id/btnEditAge"
                        android:src="@android:drawable/ic_menu_edit"
                        android:background="?android:attr/selectableItemBackground"
                        android:tint="#FFFF00"
                        android:layout_width="40dp"
                        android:layout_height="40dp" />
				</LinearLayout>

				<Button
                    android:id="@+id/btnChangePassword"
                    android:text="Change Password"
                    android:backgroundTint="#b30000"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

			</LinearLayout>
		</LinearLayout>
	</ScrollView>
</LinearLayout>