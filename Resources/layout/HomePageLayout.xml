<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#336933">

	<androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#225522"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

	<LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="20dp">

		<TextView
            android:text="TEXAS HOLD'EM"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

		<TextView
            android:text="Your Balance:"
            android:textColor="#CCCCCC"
            android:textSize="18sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

		<TextView
            android:id="@+id/homeBalanceText"
            android:text="50,000"
            android:textColor="#FFFF00"
            android:textSize="40sp"
            android:textStyle="bold"
            android:layout_marginBottom="30dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

		<Button
            android:id="@+id/btnOfflinePoker"
            android:text="Play Offline (Bots)"
            android:textSize="18sp"
            android:backgroundTint="#b30000"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

		<Button
            android:id="@+id/btnOnlinePoker"
            android:text="Play Online"
            android:textSize="18sp"
            android:backgroundTint="#0000b3"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

		<Button
            android:id="@+id/btnTutorial"
            android:text="Tutorial"
            android:backgroundTint="#222222"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

		<Button
            android:id="@+id/btnTrivia"
            android:text="Trivia"
            android:backgroundTint="#222222"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

		<Button
            android:id="@+id/btnStats"
            android:text="Statistics"
            android:backgroundTint="#222222"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

	</LinearLayout>
</LinearLayout>