<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

	<androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#225522"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

	<LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#336933"
        android:padding="5dp">

		<Button
            android:id="@+id/btnTabMine"
            android:text="My Stats"
            android:backgroundTint="#222222"
            android:textColor="#FFFFFF"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginRight="5dp"/>

		<Button
            android:id="@+id/btnTabWorld"
            android:text="World Stats"
            android:backgroundTint="#555555"
            android:textColor="#AAAAAA"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"/>
	</LinearLayout>

	<ScrollView
        android:id="@+id/scrollMine"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

		<LinearLayout
            android:id="@+id/listMine"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
		</LinearLayout>

	</ScrollView>

	<LinearLayout
        android:id="@+id/layoutWorld"
        android:visibility="gone"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="20dp">

		<TextView
            android:text="🌍"
            android:textSize="60sp"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

		<TextView
            android:text="World Database\nComing Soon..."
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

	</LinearLayout>
</LinearLayout>