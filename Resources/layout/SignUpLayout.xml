<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#336933">

	<androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#225522"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

	<ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

		<LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

			<EditText
                android:id="@+id/editTextId"
                android:hint="ID (9 digits)"
                android:textColor="#FFFFFF"
                android:textColorHint="#BBBBBB"
                android:backgroundTint="#FFFFFF"
                android:inputType="number"
                android:maxLength="9"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
			<TextView android:id="@+id/errorId" android:textColor="#FF6666" android:visibility="gone" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />

			<EditText
                android:id="@+id/editTextFullName"
                android:hint="Full Name"
                android:textColor="#FFFFFF"
                android:textColorHint="#BBBBBB"
                android:backgroundTint="#FFFFFF"
                android:inputType="textPersonName"
                android:maxLength="32"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
			<TextView android:id="@+id/errorFullName" android:textColor="#FF6666" android:visibility="gone" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />

			<TextView
                android:id="@+id/textViewDob"
                android:text="Select Date of Birth"
                android:layout_marginTop="10dp"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:padding="10dp"
                android:background="#225522"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
			<TextView android:id="@+id/errorDob" android:textColor="#FF6666" android:visibility="gone" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />

			<EditText
                android:id="@+id/editTextEmail"
                android:hint="Email"
                android:textColor="#FFFFFF"
                android:textColorHint="#BBBBBB"
                android:backgroundTint="#FFFFFF"
                android:inputType="textEmailAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
			<TextView android:id="@+id/errorEmail" android:textColor="#FF6666" android:visibility="gone" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />

			<EditText
                android:id="@+id/editTextPassword"
                android:hint="Password"
                android:textColor="#FFFFFF"
                android:textColorHint="#BBBBBB"
                android:backgroundTint="#FFFFFF"
                android:inputType="textPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
			<TextView android:id="@+id/errorPassword" android:textColor="#FF6666" android:visibility="gone" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />

			<EditText
                android:id="@+id/editTextConfirmPassword"
                android:hint="Confirm Password"
                android:textColor="#FFFFFF"
                android:textColorHint="#BBBBBB"
                android:backgroundTint="#FFFFFF"
                android:inputType="textPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
			<TextView android:id="@+id/errorConfirmPassword" android:textColor="#FF6666" android:visibility="gone" android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />

			<Button
                android:id="@+id/buttonRegister"
                android:text="Register"
                android:backgroundTint="#b30000"
                android:textColor="#FFFFFF"
                android:layout_marginTop="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

			<TextView
                android:id="@+id/errorSummary"
                android:textColor="#FF6666"
                android:visibility="gone"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

		</LinearLayout>
	</ScrollView>
</LinearLayout>